{
  "headers": [
    {
      "source": "/(.*)\\.(css|js)$",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300, must-revalidate" }
      ]
    },
    {
      "source": "/(.*)\\.(svg|png)$",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" }
      ]
    }
  ],
  "routes": [
    { "src": "^/api/generate$", "dest": "/api/generate.js" },
    { "src": "^/api/status$", "dest": "/api/status.js" },
    { "src": "^/$", "dest": "/index.html" },
    { "src": "^/404/?$", "dest": "/404.html" },
    { "src": "^/blog/?$", "dest": "/blog/index.html" },
    { "src": "^/examples/?$", "dest": "/examples.html" },
    { "src": "^/ai-generator/?$", "dest": "/ai-generator.html" },
    { "src": "^/setup/?$", "dest": "/setup.html" },
    { "src": "^/roadmap/?$", "dest": "/roadmap.html" },
    { "src": "^/about/?$", "dest": "/about.html" },
    { "src": "^/contact/?$", "dest": "/contact.html" },
    { "src": "^/privacy-policy/?$", "dest": "/privacy-policy.html" },
    { "src": "^/terms-of-service/?$", "dest": "/terms-of-service.html" },
    { "handle": "filesystem" },
    { "src": "/.*", "dest": "/404.html", "status": 404 }
  ]
}
